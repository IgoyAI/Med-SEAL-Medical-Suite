@startuml architecture

skinparam backgroundColor white
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundCorner 8
skinparam nodesep 10
skinparam ranksep 16

title <size:20><b>Med-SEAL Medical Suite</b></size>\n<size:14>System Architecture</size>\n

' ════════════════════════════════════════
'  ROW 1: Edge + Gateway
' ════════════════════════════════════════

cloud "**Cloudflare**\nDNS / CDN / DDoS" as CF #EFF6FF

rectangle "**Nginx Gateway** — TLS + Domain Routing (*.med-seal.org)" as GW #E0E7FF

CF -down-> GW : HTTPS

' ════════════════════════════════════════
'  ROW 2: All user-facing services
' ════════════════════════════════════════

together {
  rectangle "**ClinOS**\nClinician Dashboard\napp.med-seal.org" as CLINOS #DBEAFE
  rectangle "**CDSS**\nClinical Decision\nSupport\ncdss.med-seal.org" as CDSS #DBEAFE
  rectangle "**SSO-v2**\n2FA + Singpass" as SSO #E0E7FF
  rectangle "**Medplum App**\nFHIR Admin\nmedplum.med-seal.org" as MAPP #DCFCE7
}

GW -down-> CLINOS
GW -down-> CDSS
GW -down-> MAPP

' ════════════════════════════════════════
'  ROW 3: Backend API + Clinical stores
' ════════════════════════════════════════

together {
  rectangle "**AI Service**\nExpress.js Backend\napi.med-seal.org" as API #DBEAFE
  rectangle "**Medplum FHIR R4**\nHealth Data Exchange\nfhir.med-seal.org" as FHIR #DCFCE7
  rectangle "**OpenEMR**\nElectronic Medical\nRecords\nemr.med-seal.org" as EMR #FEF3C7
}

CLINOS -down-> API
CDSS -down-> API
SSO -down-> API : Auth
GW -down-> API
API -right-> FHIR : FHIR R4
API -right-> EMR : MySQL

' ════════════════════════════════════════
'  ROW 4: Multi-Agent AI
' ════════════════════════════════════════

rectangle "**Med-SEAL Agent** — LangGraph Multi-Agent AI" as AGENTBOX #FFF7ED {
  together {
    rectangle "A1 Companion\n//SEA-LION v4//" as A1 #FED7AA
    rectangle "A2 Clinical\n//Med-SEAL V1//" as A2 #FED7AA
    rectangle "A3 Nudge\n//SEA-LION v4//" as A3 #FED7AA
    rectangle "A4 Lifestyle\n//SEA-LION v4//" as A4 #FED7AA
    rectangle "A5 Insight\n//SEA-LION v4//" as A5 #FED7AA
    rectangle "A6 Doctor CDS\n//Qwen 3.6 Plus//" as A6 #FED7AA
    rectangle "Pre-Visit\n//Deterministic//" as PV #FDE68A
  }
  rectangle "**Safety Guards** — Rule-based (21 patterns) + SEA-Guard LLM" as GUARD #FEE2E2
}

API -down-> AGENTBOX : REST / SSE

note right of AGENTBOX
  Agents query FHIR R4
  via Medplum for patient
  data (read/write)
end note

' ════════════════════════════════════════
'  ROW 5: Data
' ════════════════════════════════════════

together {
  database "**PostgreSQL 16**\nMedplum + SSO" as PG #ECFDF5
  database "**MariaDB 10.11**\nOpenEMR" as MDB #ECFDF5
  database "**Redis 7**\nCache" as RD #ECFDF5
}

FHIR -down-> PG
FHIR -down-> RD
EMR -down-> MDB
SSO -down-> PG

@enduml
